{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "local": true,
  "remote": {
    "urls": [
      "http://localhost:5600/*",
      "http://127.0.0.1:5600/*",
      "http://localhost:*/*",
      "http://127.0.0.1:*/*"
    ]
  },
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-set-focus",
    "core:window:allow-start-dragging",
    "shell:allow-open",
    "dialog:default",
    "opener:default"
  ]
}
